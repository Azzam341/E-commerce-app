<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Shopping Cart</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>

<body>

<div class="container py-5">

  <h2 class="mb-4">
    Shopping Cart
  </h2>

  <!-- BACK BUTTON -->
  <a href="/" class="btn btn-outline-secondary mb-3">
    ← Back to Home
  </a>

  <% if(cart.length === 0) { %>

    <div class="alert alert-info">
      Your cart is empty.
    </div>

  <% } else { %>

    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="alert alert-success"> <%= successMessage %> </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="alert alert-danger"> <%= errorMessage %> </div>
    <% } %>

    <table class="table table-bordered align-middle">

      <thead>
        <tr>
          <th>Image</th>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% cart.forEach(item => { %>

          <tr>

            <!-- IMAGE -->
            <td width="120">
              <img
                src="<%= item.image %>"
                class="img-fluid"
              >
            </td>

            <!-- NAME -->
            <td>
              <%= item.name %>
            </td>

            <!-- PRICE -->
            <td>
              PKR <%= item.price.toLocaleString() %>
            </td>

            <!-- QUANTITY CONTROLS -->
            <td class="d-flex align-items-center gap-2">

              <a href="/cart/decrease/<%= item.productId %>"
                 class="btn btn-sm btn-outline-danger">
                −
              </a>

              <span>
                <%= item.quantity %>
              </span>

              <a href="/cart/increase/<%= item.productId %>"
                 class="btn btn-sm btn-outline-success">
                +
              </a>

            </td>

            <!-- TOTAL -->
            <td>
              PKR <%= (item.price * item.quantity).toLocaleString() %>
            </td>

            <!-- REMOVE -->
            <td>
              <a
                href="/cart/remove/<%= item.productId %>"
                class="btn btn-danger btn-sm"
              >
                Remove
              </a>
            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

    <!-- TOTAL SUMMARY -->
    <div class="text-end">

      <h4 class="mb-3">
        Total: PKR <%= total.toLocaleString() %>
      </h4>

<form method="POST" action="/cart/checkout">

  <% if(!user) { %>
    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">Shipping Address (Guest Checkout)</h5>

        <div class="row g-2">
          <div class="col-md-6">
            <label class="form-label">Full name</label>
            <input name="fullName" class="form-control" placeholder="John Doe">
          </div>
          <div class="col-md-6">
            <label class="form-label">Email (optional)</label>
            <input name="email" class="form-control" placeholder="you@example.com">
          </div>
          <div class="col-12">
            <label class="form-label">Street address</label>
            <input name="street" class="form-control" placeholder="123 Main St">
          </div>
          <div class="col-md-4">
            <label class="form-label">City</label>
            <input name="city" class="form-control" placeholder="Karachi">
          </div>
          <div class="col-md-4">
            <label class="form-label">State</label>
            <input name="state" class="form-control" placeholder="Sindh">
          </div>
          <div class="col-md-4">
            <label class="form-label">ZIP / Postal Code</label>
            <input name="zip" class="form-control" placeholder="75500">
          </div>
          <div class="col-md-6">
            <label class="form-label">Country</label>
            <input name="country" class="form-control" placeholder="Pakistan">
          </div>
          <div class="col-md-6">
            <label class="form-label">Phone</label>
            <input name="phone" class="form-control" placeholder="0312-1234567">
          </div>
        </div>

      </div>
    </div>
  <% } %>

  <button class="btn btn-primary">
    Checkout
  </button>
</form>

    </div>

  <% } %>

</div>

</body>
</html>