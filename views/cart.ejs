<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Shopping Cart</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>

<body>

<div class="container py-5">

  <h2 class="mb-4">
    Shopping Cart
  </h2>

  <!-- BACK BUTTON -->
  <a href="/" class="btn btn-outline-secondary mb-3">
    ← Back to Home
  </a>

  <% if(cart.length === 0) { %>

    <div class="alert alert-info">
      Your cart is empty.
    </div>

  <% } else { %>

    <table class="table table-bordered align-middle">

      <thead>
        <tr>
          <th>Image</th>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% cart.forEach(item => { %>

          <tr>

            <!-- IMAGE -->
            <td width="120">
              <img
                src="<%= item.image %>"
                class="img-fluid"
              >
            </td>

            <!-- NAME -->
            <td>
              <%= item.name %>
            </td>

            <!-- PRICE -->
            <td>
              PKR <%= item.price.toLocaleString() %>
            </td>

            <!-- QUANTITY CONTROLS -->
            <td class="d-flex align-items-center gap-2">

              <a href="/cart/decrease/<%= item.productId %>"
                 class="btn btn-sm btn-outline-danger">
                −
              </a>

              <span>
                <%= item.quantity %>
              </span>

              <a href="/cart/increase/<%= item.productId %>"
                 class="btn btn-sm btn-outline-success">
                +
              </a>

            </td>

            <!-- TOTAL -->
            <td>
              PKR <%= (item.price * item.quantity).toLocaleString() %>
            </td>

            <!-- REMOVE -->
            <td>
              <a
                href="/cart/remove/<%= item.productId %>"
                class="btn btn-danger btn-sm"
              >
                Remove
              </a>
            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

    <!-- TOTAL SUMMARY -->
    <div class="text-end">

      <h4 class="mb-3">
        Total: PKR <%= total.toLocaleString() %>
      </h4>

<form method="POST" action="/cart/checkout">
  <button class="btn btn-primary">
    Checkout
  </button>
</form>

    </div>

  <% } %>

</div>

</body>
</html>