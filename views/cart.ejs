<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Shopping Cart</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #f6f7fb, #eef2f7);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .cart-wrapper {
      padding: 30px 10px;
    }

    .page-title {
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    /* CART CARD */
    .cart-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      overflow: hidden;
    }

    .cart-header {
      padding: 15px 18px;
      border-bottom: 1px solid #eef0f3;
      font-weight: 600;
    }

    table {
      min-width: 900px;
    }

    /* IMAGE */
    .cart-img {
      width: 70px;
      height: 70px;
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid #e5e7eb;
    }

    /* QTY BUTTONS */
    .qty-btn {
      border-radius: 8px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    /* SUMMARY */
    .summary-box {
      background: #fff;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      margin-top: 20px;
    }

    .checkout-btn {
      border-radius: 12px;
      padding: 10px 16px;
      font-weight: 500;
      width: 100%;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border: none;
      color: #fff;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .checkout-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 24px rgba(99, 102, 241, 0.3);
    }

    /* ADDRESS CARD */
    .address-card {
      border-radius: 14px;
      background: #fafafa;
      border: 1px solid #eee;
    }

    .form-control {
      border-radius: 10px;
      padding: 10px 12px;
    }

    .btn {
      border-radius: 10px;
    }

    .btn-outline-danger {
      background: #fff;
      color: #dc2626;
      border: 1px solid #fca5a5;
    }

    .btn-outline-danger:hover {
      background: #fee2e2;
      color: #b91c1c;
    }

    .btn-outline-success {
      background: #fff;
      color: #16a34a;
      border: 1px solid #86efac;
    }

    .btn-outline-success:hover {
      background: #dcfce7;
      color: #166534;
    }

    .back-btn {
      border-radius: 10px;
    }
  </style>
</head>

<body>

  <main class="cart-wrapper container-fluid container-md">

    <!-- TITLE -->
    <header class="mb-3">
      <h2 class="page-title">Shopping Cart</h2>

      <a href="/" class="btn btn-outline-secondary back-btn mt-2">
        ← Back to Home
      </a>
    </header>

    <% if(cart.length === 0) { %>

      <div class="alert alert-info rounded-3">
        Your cart is empty.
      </div>

    <% } else { %>

      <% if (typeof successMessage !== 'undefined' && successMessage) { %>
        <div class="alert alert-success rounded-3">
          <%= successMessage %>
        </div>
      <% } %>

      <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="alert alert-danger rounded-3">
          <%= errorMessage %>
        </div>
      <% } %>

      <!-- CART TABLE -->
      <section class="cart-card">

        <div class="cart-header">
          Cart Items
        </div>

        <div class="table-responsive p-2 p-md-3">

          <table class="table table-hover align-middle mb-0">

            <thead class="table-light">
              <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
              </tr>
            </thead>

            <tbody>

              <% cart.forEach(item => { %>

                <tr>

                  <td>
                    <img src="<%= item.image %>" class="cart-img">
                  </td>

                  <td class="fw-semibold">
                    <%= item.name %>
                  </td>

                  <td>
                    PKR <%= item.price.toLocaleString() %>
                  </td>

                  <td>
                    <div class="d-flex align-items-center gap-2">

                      <a href="/cart/decrease/<%= item.productId %>"
                         class="btn btn-sm btn-outline-danger qty-btn">
                        −
                      </a>

                      <span class="fw-semibold">
                        <%= item.quantity %>
                      </span>

                      <a href="/cart/increase/<%= item.productId %>"
                         class="btn btn-sm btn-outline-success qty-btn">
                        +
                      </a>

                    </div>
                  </td>

                  <td class="fw-semibold">
                    PKR <%= (item.price * item.quantity).toLocaleString() %>
                  </td>

                  <td>
                    <a href="/cart/remove/<%= item.productId %>"
                       class="btn btn-danger btn-sm">
                      Remove
                    </a>
                  </td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

      </section>

      <!-- SUMMARY -->
      <div class="summary-box">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="mb-0">Total</h4>
          <h4 class="mb-0">
            PKR <%= total.toLocaleString() %>
          </h4>
        </div>

        <!-- CHECKOUT -->
        <form method="POST" action="/cart/checkout">

          <% if(!user) { %>

            <div class="address-card p-3 mb-3">

              <h5 class="mb-3">Shipping Address (Guest Checkout)</h5>

              <div class="row g-2">

                <div class="col-md-6">
                  <input name="fullName" class="form-control" placeholder="Full name">
                </div>

                <div class="col-md-6">
                  <input name="email" class="form-control" placeholder="Email (optional)">
                </div>

                <div class="col-12">
                  <input name="street" class="form-control" placeholder="Street address">
                </div>

                <div class="col-md-4">
                  <input name="city" class="form-control" placeholder="City">
                </div>

                <div class="col-md-4">
                  <input name="state" class="form-control" placeholder="State">
                </div>

                <div class="col-md-4">
                  <input name="zip" class="form-control" placeholder="ZIP">
                </div>

                <div class="col-md-6">
                  <input name="country" class="form-control" placeholder="Country">
                </div>

                <div class="col-md-6">
                  <input name="phone" class="form-control" placeholder="Phone">
                </div>

              </div>

            </div>

          <% } %>

          <button class="btn btn-primary checkout-btn">
            Proceed to Checkout
          </button>

        </form>

      </div>

    <% } %>

  </main>

</body>

</html>