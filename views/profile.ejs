<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
  <a class="navbar-brand" href="/">Store</a>
  <div class="collapse navbar-collapse">
    <ul class="navbar-nav ms-auto">
      <li class="nav-item me-2">
        <a class="btn btn-outline-light" href="/cart">Cart <span class="badge bg-secondary"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span></a>
      </li>
      <li class="nav-item me-2">
        <a class="btn btn-outline-light" href="/">Home</a>
      </li>
      <li class="nav-item">
        <a class="btn btn-danger" href="/logout">Logout</a>
      </li>
    </ul>
  </div>
</nav>

<div class="container mt-5">
  <div class="row">
    <div class="col-lg-4 mb-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h4 class="card-title mb-3">My Profile</h4>

          <% if (successMessage) { %>
            <div class="alert alert-success"> <%= successMessage %> </div>
          <% } %>
          <% if (errorMessage) { %>
            <div class="alert alert-danger"> <%= errorMessage %> </div>
          <% } %>

          <form action="/profile" method="POST">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" value="<%= user.email %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Phone</label>
              <input type="tel" name="phone" class="form-control" value="<%= user.phone || '' %>">
            </div>

            <div class="mb-3">
              <label class="form-label">Street</label>
              <input type="text" name="street" class="form-control" value="<%= user.address?.street || '' %>">
            </div>

            <div class="mb-3">
              <label class="form-label">City</label>
              <input type="text" name="city" class="form-control" value="<%= user.address?.city || '' %>">
            </div>

            <div class="mb-3">
              <label class="form-label">State</label>
              <input type="text" name="state" class="form-control" value="<%= user.address?.state || '' %>">
            </div>

            <div class="mb-3">
              <label class="form-label">ZIP / Postal Code</label>
              <input type="text" name="zip" class="form-control" value="<%= user.address?.zip || '' %>">
            </div>

            <div class="mb-3">
              <label class="form-label">Country</label>
              <input type="text" name="country" class="form-control" value="<%= user.address?.country || '' %>">
            </div>

            <button type="submit" class="btn btn-primary w-100">Save Profile</button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <h4 class="card-title mb-4">Order History</h4>

          <% if (orders.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Items</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach(order => { %>
                    <tr>
                      <td><%= order._id %></td>
                      <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                      <td><%= order.status %></td>
                      <td>
                        <ul class="list-unstyled mb-0">
                          <% order.items.forEach(item => { %>
                            <li><strong><%= item.name %></strong> x<%= item.quantity %></li>
                          <% }) %>
                        </ul>
                      </td>
                      <td>$<%= order.totalPrice.toFixed(2) %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted">No orders placed yet.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
