  <!-- PAGINATION -->
  <div class="d-flex justify-content-center mt-4 gap-2">

    <% if(currentPage > 1) { %>
      <a class="btn btn-outline-primary"
         href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
        Previous
