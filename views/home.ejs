            src="<%= product.image %>"
            class="card-img-top"
            alt="<%= product.name %>"
            style="height: 180px; object-fit: cover;"
          >

          <div class="card-body">

            <h6 class="card-title">
              <%= product.name %>
            </h6>

            <p class="mb-1 text-muted">
              Stock: <%= product.stock %>
            </p>

            <p class="mb-1 fw-bold">
              PKR <%= product.price.toLocaleString() %>
            </p>

            <p class="mb-2">
              ⭐ <%= product.rating %>
            </p>

            <button
  class="btn btn-success w-100 add-to-cart"
  data-id="<%= product._id %>"
>
  Add to Cart
</button>

          </div>

        </div>

      </div>

    <% }) %>

