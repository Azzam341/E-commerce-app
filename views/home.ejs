<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Store</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg: #0f1724;
      --surface: #ffffff;
      --muted: #6b7280;
      --accent: #6d28d9; /* violet */
      --accent-2: #06b6d4; /* teal */
      --card-shadow: 0 8px 30px rgba(13, 14, 23, 0.08);
      --radius: 14px;
    }

    html,body{height:100%;}
    body {
      font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;
      background: linear-gradient(180deg,#f8fafc 0%, #eef2ff 100%);
      color: #0f1724;
      margin: 0;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
    }

    header.site-header{background:transparent;padding:12px 0;position:sticky;top:0;z-index:40}
    .site-nav{display:flex;align-items:center;gap:16px}
    .brand{display:flex;align-items:center;gap:12px}
    .brand img{height:38px}
    .search-input{min-width:220px;max-width:420px}

    .hero-banner{background:linear-gradient(90deg, rgba(109,40,217,0.08), rgba(6,182,212,0.03));border-radius:12px;padding:18px;margin:18px 0;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .hero-copy h1{font-weight:700;margin:0 0 6px 0}
    .hero-copy p{margin:0;color:var(--muted)}

    main{padding:18px}
    .grid-cards{display:grid;grid-template-columns:repeat(1,1fr);gap:18px}
    @media(min-width:768px){.grid-cards{grid-template-columns:repeat(2,1fr)}}
    @media(min-width:1200px){.grid-cards{grid-template-columns:repeat(4,1fr)}}

    .product-card{background:var(--surface);border-radius:var(--radius);overflow:hidden;box-shadow:var(--card-shadow);transition:transform .22s ease,box-shadow .22s ease}
    .product-card:hover{transform:translateY(-6px);box-shadow:0 18px 40px rgba(13,14,23,0.12)}
    .product-media{height:180px;background:#f3f4f6;display:flex;align-items:center;justify-content:center}
    .product-media img{width:100%;height:100%;object-fit:cover}
    .product-body{padding:14px}
    .product-title{font-weight:600;margin:0 0 6px}
    .product-meta{color:var(--muted);font-size:13px}
    .product-price{font-weight:700;color:var(--accent);}

    .btn{border-radius:10px}
    .btn-primary{background:linear-gradient(90deg,var(--accent),#8b5cf6);border:none;color:#fff}
    .btn-ghost{background:transparent;border:1px solid rgba(15,23,36,0.06);color:var(--muted)}

    /* Best Selling */
    .best-selling .card{display:flex;gap:12px;align-items:center;padding:12px}
    .best-img{width:80px;height:80px;border-radius:8px;background:#f3f4f6;overflow:hidden}

    /* pagination */
    .pagination-wrap{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;padding:22px 0}

    footer.site-footer{margin-top:40px;padding:32px 18px;background:#0b1220;color:#cbd5e1;border-radius:12px}
    footer a{color:#cbd5e1}
  </style>
</head>

<body>

  <header class="site-header container">
    <nav class="site-nav">
      <div class="brand">
        <a href="/"><img id="main-logo" src="/assets/Tejarlogo.svg" alt="logo"></a>
        <div>
          <div style="font-weight:700">Tejar</div>
          <div style="font-size:12px;color:var(--muted)">Quality store</div>
        </div>
      </div>

      <div style="flex:1;display:flex;justify-content:center">
        <form method="GET" action="/" style="width:100%;max-width:700px;">
          <input class="form-control search-input" type="text" name="search" placeholder="Search products, categories or brands" value="<%= search %>">
        </form>
      </div>

      <div style="display:flex;align-items:center;gap:10px">
        <a href="/cart" class="btn btn-ghost">Cart <span id="cart-count" class="badge bg-light text-dark ms-2"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span></a>
        <% if(user) { %>
          <a href="/profile" class="btn btn-ghost">Profile</a>
        <% } else { %>
          <a href="/login" class="btn btn-primary">Login</a>
        <% } %>
      </div>
    </nav>
  </header>

  <main class="container">
    <section class="hero-banner">
      <div class="hero-copy">
        <h1>Discover quality products</h1>
        <p>Fast delivery • Secure payments • Trusted sellers</p>
      </div>
      <div>
        <a href="/admin" class="btn btn-ghost">Seller / Admin</a>
      </div>
    </section>

    <!-- Product Grid -->
    <section aria-label="Products">
      <div class="grid-cards" id="product-cards-container">
        <% products.forEach(product => { %>
          <article class="product-card">
            <div class="product-media">
              <img src="<%= product.image %>" alt="<%= product.name %>">
            </div>
            <div class="product-body">
              <h3 class="product-title"><%= product.name %></h3>
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div class="product-meta">Stock: <%= product.stock %></div>
                  <div class="product-price">PKR <%= product.price.toLocaleString() %></div>
                </div>
                <div class="d-flex flex-column align-items-end gap-2">
                  <button class="btn btn-outline-secondary btn-sm quick-view-btn" 
                          data-id="<%= product._id %>"
                          data-name="<%= product.name %>"
                          data-desc="<%= product.description || 'No descriptive details available for this item.' %>"
                          data-price="PKR <%= product.price.toLocaleString() %>"
                          data-image="<%= product.image %>"
                          data-rating="<%= product.rating || '4.5' %>"
                          data-stock="<%= product.stock %>">
                    Quick View
                  </button>
                  <button class="btn btn-primary btn-sm add-to-cart" data-id="<%= product._id %>">Add to Cart</button>
                </div>
              </div>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="pagination-wrap">
        <% if(currentPage > 1) { %>
          <a class="btn btn-ghost" href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">← Prev</a>
        <% } %>

        <% for(let i = 1; i <= totalPages; i++) { %>
          <a class="btn <%= i === currentPage ? 'btn-primary' : 'btn-ghost' %>" href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"><%= i %></a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a class="btn btn-ghost" href="?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">Next →</a>
        <% } %>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container">
        <div class="row">
          <div class="col-md-4">
            <h5>Customer Service</h5>
            <a href="#">Help</a><br>
            <a href="#">Contact</a>
          </div>
          <div class="col-md-4">
            <h5>Company</h5>
            <a href="#">About</a><br>
            <a href="#">Careers</a>
          </div>
          <div class="col-md-4">
            <h5>Account</h5>
            <a href="/login">Login/Register</a>
          </div>
        </div>
      </div>
    </footer>

  </main>

  <!-- Keep original modal, toast and scripts intact (EJS logic preserved) -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

  <div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content shadow-lg border-0">
        <div class="modal-header bg-light">
          <h5 class="modal-title fw-bold text-dark" id="quickViewModalLabel">Product Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="text-center mb-3">
            <img id="modal-product-img" src="" alt="" class="img-fluid rounded" style="max-height: 250px; object-fit: cover;">
          </div>
          <h4 id="modal-product-name" class="fw-bold mb-2 text-dark"></h4>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span id="modal-product-price" class="fs-5 fw-bold text-success"></span>
          </div>
          <p id="modal-product-desc" class="text-secondary leading-relaxed mb-0"></p>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" id="modal-add-to-cart-btn" class="btn btn-success px-4" data-id="">Add to Cart</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3000">
      <div class="d-flex">
        <div class="toast-body fw-semibold">🛒 Item added to cart successfully!</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Preserve original client-side behavior for quick view and add-to-cart
    document.addEventListener('DOMContentLoaded', () => {
      const toastElement = document.getElementById('cartToast');
      const cartToast = new bootstrap.Toast(toastElement);

      const viewModalElement = document.getElementById('quickViewModal');
      const quickViewModal = new bootstrap.Modal(viewModalElement);

      const runAddToCartRoute = async (buttonTarget, idAttribute) => {
        const res = await fetch(`/cart/add/${idAttribute}`, { method: 'GET', headers: { 'Accept': 'application/json' } });
        if (!res.ok) { console.error('Add to cart failed', res.status); return; }
        const data = await res.json();
        if (data.success) {
          const cartCount = document.querySelector('#cart-count');
          if (cartCount) { cartCount.innerText = data.cartCount; }
          cartToast.show();
          const primaryText = buttonTarget.innerText;
          buttonTarget.innerText = 'Added ✔';
          buttonTarget.disabled = true;
          setTimeout(() => { buttonTarget.innerText = primaryText; buttonTarget.disabled = false; }, 1000);
        }
      };

      const cardsContainer = document.getElementById('product-cards-container');
      cardsContainer && cardsContainer.addEventListener('click', (event) => {
        const target = event.target;
        if (target.classList.contains('add-to-cart')) {
          const productId = target.getAttribute('data-id');
          runAddToCartRoute(target, productId);
        }
        if (target.classList.contains('quick-view-btn')) {
          document.getElementById('modal-product-name').innerText = target.getAttribute('data-name');
          document.getElementById('modal-product-desc').innerText = target.getAttribute('data-desc');
          document.getElementById('modal-product-price').innerText = target.getAttribute('data-price');
          const imgTarget = document.getElementById('modal-product-img');
          imgTarget.src = target.getAttribute('data-image');
          imgTarget.alt = target.getAttribute('data-name');
          const modalCartBtn = document.getElementById('modal-add-to-cart-btn');
          modalCartBtn.setAttribute('data-id', target.getAttribute('data-id'));
          setTimeout(() => { quickViewModal.show(); }, 0);
        }
      });

      document.getElementById('modal-add-to-cart-btn')?.addEventListener('click', function() {
        const productId = this.getAttribute('data-id');
        runAddToCartRoute(this, productId);
        quickViewModal.hide();
      });

      viewModalElement?.addEventListener('hidden.bs.modal', () => { document.querySelectorAll('.modal-backdrop').forEach(el => el.remove()); document.body.style.overflow = 'auto'; document.body.style.paddingRight = '0px'; });
    });
  </script>

</body>

</html>