<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      /* Prevent stacking context lockouts by strictly prioritizing core Bootstrap layout states */
      .modal {
        z-index: 1060 !important;
      }
      .modal-backdrop {
        z-index: 1050 !important;
      }
      .toast-container {
        z-index: 1100 !important;
      }
    </style>
  </head>
  <body>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
          <div class="modal-header bg-light">
            <h5 class="modal-title fw-bold text-dark" id="quickViewModalLabel">Product Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="text-center mb-3">
              <img id="modal-product-img" src="" alt="" class="img-fluid rounded" style="max-height: 250px; object-fit: cover;">
            </div>
            <h4 id="modal-product-name" class="fw-bold mb-2 text-dark"></h4>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span id="modal-product-price" class="fs-5 fw-bold text-success"></span>
            </div>
            <p id="modal-product-desc" class="text-secondary leading-relaxed mb-0"></p>
          </div>
          <div class="modal-footer bg-light">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" id="modal-add-to-cart-btn" class="btn btn-success px-4" data-id="">Add to Cart</button>
          </div>
        </div>
      </div>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3">
      <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3000">
        <div class="d-flex">
          <div class="toast-body fw-semibold">
            🛒 Item added to cart successfully!
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
      </div>
    </div>

    <header class="bg-light shadow-sm">
      <nav class="navbar navbar-expand-lg navbar-light bg-light container py-2">
        <a class="navbar-brand d-flex align-items-center" href="/">
          <img id="main-logo" src="/assets/Tejarlogo.svg" alt="logo" height="40" class="me-2">
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/cart">
                Cart <span id="cart-count" class="badge bg-secondary"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
              </a>
            </li>
          </ul>

          <div class="d-flex align-items-center gap-3 flex-grow-1 flex-lg-grow-0 justify-content-end">
            <form method="GET" action="/" class="m-0" style="min-width: 250px;">
              <input type="text" name="search" class="form-control" placeholder="Search products..." value="<%= search %>">
            </form>

            <div class="d-flex gap-2 whitespace-nowrap">
              <% if(user) { %>
                <a href="/profile" class="btn btn-outline-secondary">Profile</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
              <% } else { %>
                <a href="/login" class="btn btn-outline-primary">Log in</a>
                <a href="/register" class="btn btn-success">Register</a>
              <% } %>
            </div>
          </div>

        </div>
      </nav>
    </header>

    <section id="options-pane">
      <nav class="navbar">
        <button class="hamburger" id="hamburger-menu">☰</button>
        <ul class="horizontal-menu" id="nav-links">
          <li><button class="btn">Home</button></li>
          <li><button>Deals</button></li>
          <li><button>Featured</button></li>
          <li><button>New Arrival</button></li>
          <li><button>Best Seller</button></li>
          <li><button>Most Viewed</button></li>
        </ul>
      </nav>
    </section>

    <section id="banners">
      <div id="topmost-banner"></div>
      <div class="banner-para-div">
        <p class="banner-para">100% Genuine Products</p>
        <p class="banner-para">Discounts Offered Every Day</p>
        <p class="banner-para">Free Shipping</p>
      </div>
    </section>

    <section id="deals" class="container my-4">

      <form method="GET" action="/" class="mb-4">
        
        <div class="text-start mb-3">
          <button type="button" class="btn btn-outline-dark px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2" data-bs-toggle="collapse" data-bs-target="#masterFilterTray" aria-expanded="false" aria-controls="masterFilterTray">
            <span>Filter Products</span>
          </button>
        </div>

        <div class="collapse" id="masterFilterTray">
          <div class="card card-body bg-light border-0 shadow-sm p-4 mb-3">
            <div class="row g-3">
              
              <div class="col-md-4">
                <label class="form-label small fw-bold text-dark">Category Selection</label>
                <select name="category" class="form-select">
                  <option value="">All Electronics</option>
                  <option value="Video Games" <%= category === 'Video Games' ? 'selected' : '' %>>Video Games & Consoles</option>
                  <option value="Headphones" <%= category === 'Headphones' ? 'selected' : '' %>>Headphones & Audio</option>
                  <option value="Smartphones" <%= category === 'Smartphones' ? 'selected' : '' %>>Smartphones & Tablets</option>
                  <option value="Laptops" <%= category === 'Laptops' ? 'selected' : '' %>>Laptops & Computers</option>
                  <option value="Television" <%= category === 'Television' ? 'selected' : '' %>>Televisions & Home Theater</option>
                  <option value="Cameras" <%= category === 'Cameras' ? 'selected' : '' %>>Cameras & Photography</option>
                  <option value="Smart Home" <%= category === 'Smart Home' ? 'selected' : '' %>>Smart Home & IoT</option>
                  <option value="Wearables" <%= category === 'Wearables' ? 'selected' : '' %>>Smartwatches & Wearables</option>
                  <option value="Accessories" <%= category === 'Accessories' ? 'selected' : '' %>>Computer Accessories</option>
                </select>
              </div>

              <div class="col-md-3">
                <label class="form-label small fw-bold text-dark">Min Price (PKR)</label>
                <input type="number" name="minPrice" class="form-control" placeholder="0" value="<%= minPrice %>">
              </div>

              <div class="col-md-3">
                <label class="form-label small fw-bold text-dark">Max Price (PKR)</label>
                <input type="number" name="maxPrice" class="form-control" placeholder="Any" value="<%= maxPrice %>">
              </div>

              <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 fw-semibold py-2">Apply</button>
              </div>

            </div>
          </div>
        </div>
      </form>

      <div class="row g-4" id="product-cards-container">
        <% products.forEach(product => { %>
          <div class="col-xl-3 col-md-4 col-sm-6 product-card-item">
            <div class="card h-100 shadow-sm">
              <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 180px; object-fit: cover;">
              <div class="card-body d-flex flex-column justify-content-between">
                <div>
                  <h6 class="card-title fw-bold"><%= product.name %></h6>
                  <p class="mb-1 text-muted small">Stock: <%= product.stock %></p>
                  <p class="mb-1 fw-bold text-dark">PKR <%= product.price.toLocaleString() %></p>
                </div>
                <div class="mt-2 d-flex flex-column gap-1">
                  <button class="btn btn-outline-secondary btn-sm w-100 quick-view-btn" 
                          data-id="<%= product._id %>"
                          data-name="<%= product.name %>"
                          data-desc="<%= product.description || 'No descriptive details available for this item.' %>"
                          data-price="PKR <%= product.price.toLocaleString() %>"
                          data-image="<%= product.image %>"
                          data-rating="<%= product.rating || '4.5' %>"
                          data-stock="<%= product.stock %>">
                    Quick View
                  </button>
                  <button class="btn btn-success btn-sm w-100 add-to-cart" data-id="<%= product._id %>">
                    Add to Cart
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="d-flex justify-content-center mt-4 gap-2">
        <% if(currentPage > 1) { %>
          <a class="btn btn-outline-primary" href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
            Previous
          </a>
        <% } %>

        <% for(let i = 1; i <= totalPages; i++) { %>
          <a class="btn <%= i === currentPage ? 'btn-primary' : 'btn-outline-primary' %>" href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
            <%= i %>
          </a>
        <% } %>

        <% if(currentPage < totalPages) { %>
          <a class="btn btn-outline-primary" href="?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
            Next
          </a>
        <% } %>
      </div>
    </section>

    <footer>
      <div>
        <h2>Customer Service</h2>
        <div>
          <a href="">Help</a><br>
          <a href="">Contact</a><br>
          <a href="">Order Status</a>
        </div>
      </div>

      <div>
        <h2>Company</h2>
        <div>
          <a href="">About</a><br>
          <a href="">Careers</a><br>
          <a href="">Privacy</a><br>
          <a href="">Terms</a>
        </div>
      </div>

      <div>
        <h2>Account</h2>
        <div>
          <a href="">Login/Register</a><br>
        </div>
      </div>

      <div>
        <h2>Sign up for News and Offers</h2>
        <input type="text" placeholder="Enter your email">
        <p>This site is protected by reCaptcha and <br> the Google <a href="">Privacy Policy</a> and <a href="">Terms of Service</a> apply.</p>
      </div>

      <div>
        <h2>Follow Us</h2>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toastElement = document.getElementById('cartToast');
        const cartToast = new bootstrap.Toast(toastElement);
        
        const viewModalElement = document.getElementById('quickViewModal');
        const quickViewModal = new bootstrap.Modal(viewModalElement);

        // Core business logic handler
        const runAddToCartRoute = async (buttonTarget, idAttribute) => {
          const res = await fetch(`/cart/add/${idAttribute}`, {
            method: 'GET',
            headers: {
              'Accept': 'application/json'
            }
          });

          if (!res.ok) {
            console.error('Add to cart failed', res.status);
            return;
          }

          const data = await res.json();

          if (data.success) {
            const cartCount = document.querySelector('#cart-count');
            if (cartCount) {
              cartCount.innerText = data.cartCount;
            }

            cartToast.show();

            const primaryText = buttonTarget.innerText;
            buttonTarget.innerText = "Added ✔";
            buttonTarget.disabled = true;

            setTimeout(() => {
              buttonTarget.innerText = primaryText;
              buttonTarget.disabled = false;
            }, 1000);
          }
        };

        // Event Delegation Setup
        const cardsContainer = document.getElementById('product-cards-container');
        
        cardsContainer.addEventListener('click', (event) => {
          const target = event.target;

          if (target.classList.contains('add-to-cart')) {
            const productId = target.getAttribute('data-id');
            runAddToCartRoute(target, productId);
          }

          if (target.classList.contains('quick-view-btn')) {
            document.getElementById('modal-product-name').innerText = target.getAttribute('data-name');
            document.getElementById('modal-product-desc').innerText = target.getAttribute('data-desc');
            document.getElementById('modal-product-price').innerText = target.getAttribute('data-price');
            
            const imgTarget = document.getElementById('modal-product-img');
            imgTarget.src = target.getAttribute('data-image');
            imgTarget.alt = target.getAttribute('data-name');

            const modalCartBtn = document.getElementById('modal-add-to-cart-btn');
            modalCartBtn.setAttribute('data-id', target.getAttribute('data-id'));

            // Wrapped inside setTimeout to prevent rendering engine race condition freezes
            setTimeout(() => {
              quickViewModal.show();
            }, 0);
          }
        });

        // Modal Add to Cart Action Binding
        document.getElementById('modal-add-to-cart-btn').addEventListener('click', function() {
          const productId = this.getAttribute('data-id');
          runAddToCartRoute(this, productId);
          quickViewModal.hide(); // Safely dismisses modal
        });

        // Fail-safe cleanup: Clean up lingering backdrops if a user exits manually
        viewModalElement.addEventListener('hidden.bs.modal', () => {
          document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
          document.body.style.overflow = 'auto';
          document.body.style.paddingRight = '0px';
        });

        window.injectProductsFromAPI = function(apiProductsArray) {
          cardsContainer.innerHTML = '';
          
          if(!apiProductsArray || apiProductsArray.length === 0) {
            cardsContainer.innerHTML = '<div class="col-12 text-center text-muted">No products found match selection criteria</div>';
            return;
          }

          apiProductsArray.forEach(product => {
            const cardMarkup = `
              <div class="col-xl-3 col-md-4 col-sm-6 product-card-item">
                <div class="card h-100 shadow-sm">
                  <img src="${product.image}" class="card-img-top" alt="${product.name}" style="height: 180px; object-fit: cover;">
                  <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                      <h6 class="card-title fw-bold">${product.name}</h6>
                      <p class="mb-1 text-muted small">Stock: ${product.stock}</p>
                      <p class="mb-1 fw-bold text-dark">PKR ${Number(product.price).toLocaleString()}</p>
                    </div>
                    <div class="mt-2 d-flex flex-column gap-1">
                      <button class="btn btn-outline-secondary btn-sm w-100 quick-view-btn" 
                              data-id="${product._id}"
                              data-name="${product.name}"
                              data-desc="${product.description || 'No descriptive details available for this item.'}"
                              data-price="PKR ${Number(product.price).toLocaleString()}"
                              data-image="${product.image}"
                              data-rating="${product.rating || '4.5'}"
                              data-stock="${product.stock}">
                        Quick View
                      </button>
                      <button class="btn btn-success btn-sm w-100 add-to-cart" data-id="${product._id}">
                        Add to Cart
                      </button>
                    </div>
                  </div>
                </div>
              </div>`;
            cardsContainer.insertAdjacentHTML('beforeend', cardMarkup);
          });
        };
      });
    </script>
  </body>
</html>