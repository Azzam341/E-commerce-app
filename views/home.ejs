      <a class="btn <%= i === currentPage ? 'btn-primary' : 'btn-outline-primary' %>"
         href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>">
