<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;

      /* GREEN / TEAL GRADIENT THEME */
      background: linear-gradient(135deg, #11998e, #38ef7d);
    }

    /* soft glow effect */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.15), transparent 40%),
                  radial-gradient(circle at 80% 80%, rgba(255,255,255,0.10), transparent 40%);
      z-index: 0;
    }

    .register-card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;

      padding: 32px;
      border-radius: 18px;

      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);

      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.18);
    }

    .register-title {
      font-weight: 800;
      text-align: center;
      margin-bottom: 6px;
      color: #064e3b;
    }

    .subtitle {
      text-align: center;
      font-size: 13px;
      color: #6b7280;
      margin-bottom: 18px;
    }

    .form-control {
      border-radius: 10px;
      padding: 10px 12px;
    }

    .form-control:focus {
      border-color: #10b981;
      box-shadow: 0 0 0 0.2rem rgba(16, 185, 129, 0.2);
    }

    .btn-success {
      border-radius: 10px;
      padding: 10px;
      font-weight: 500;
      background: linear-gradient(135deg, #11998e, #38ef7d);
      border: none;
      transition: 0.2s ease;
    }

    .btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }
  </style>
</head>

<body>

  <div class="register-card">

    <h3 class="register-title">Create Account</h3>
    <div class="subtitle">Join us and start managing everything easily</div>

    <form method="POST" action="/register">

      <div class="mb-2">
        <input name="name" class="form-control" placeholder="Name" required>
      </div>

      <div class="mb-2">
        <input name="email" class="form-control" placeholder="Email" required>
      </div>

      <div class="mb-3">
        <input name="password" type="password" class="form-control" placeholder="Password (6+ chars)" required>
      </div>

      <button class="btn btn-success w-100">
        Register
      </button>

    </form>

    <div class="text-center mt-3">
      <p class="mb-1">Already have an account? <a href="/login">Login</a></p>
      <a href="/" class="text-decoration-none">Back to Home</a>
    </div>

  </div>

</body>

</html>