<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background: linear-gradient(135deg, #667eea, #764ba2);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* soft floating background glow */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.15), transparent 40%),
                  radial-gradient(circle at 80% 80%, rgba(255,255,255,0.10), transparent 40%);
      z-index: 0;
    }

    .login-card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      padding: 32px;
      border-radius: 18px;

      /* glass effect */
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);

      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    }

    .login-title {
      font-weight: 800;
      text-align: center;
      margin-bottom: 20px;
      color: #1f2937;
    }

    .form-control {
      border-radius: 10px;
      padding: 10px 12px;
    }

    .form-control:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.2);
    }

    .btn-primary {
      border-radius: 10px;
      padding: 10px;
      font-weight: 500;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border: none;
      transition: 0.2s ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .subtitle {
      text-align: center;
      font-size: 13px;
      color: #6b7280;
      margin-bottom: 20px;
    }
  </style>
</head>

<body>

  <div class="login-card">

    <h3 class="login-title">Login</h3>
    <div class="subtitle">Welcome back! Please enter your details.</div>

    <form method="POST" action="/login">

      <div class="mb-3">
        <input name="email" class="form-control" placeholder="Email" required>
      </div>

      <div class="mb-3">
        <input name="password" type="password" class="form-control" placeholder="Password" required>
      </div>

      <button class="btn btn-primary w-100">
        Login
      </button>

    </form>

    <div class="text-center mt-3">
      <p class="mb-1">Don't have an account? <a href="/register">Register</a></p>
      <a href="/" class="text-decoration-none">Back to Home</a>
    </div>

  </div>

</body>

</html>