<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Product</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #f6f7fb, #eef2f7);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .page-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 30px 15px;
    }

    .edit-card {
      width: 100%;
      max-width: 700px;
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }

    .edit-header {
      background: linear-gradient(135deg, #0d6efd, #4f9cff);
      color: #fff;
      padding: 18px 22px;
    }

    .edit-header h2 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
    }

    .edit-body {
      padding: 22px;
    }

    .form-label {
      font-weight: 600;
      font-size: 13px;
      color: #374151;
    }

    .form-control,
    .form-select {
      border-radius: 10px;
      padding: 10px 12px;
      border: 1px solid #e5e7eb;
      transition: 0.2s ease;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: #4f9cff;
      box-shadow: 0 0 0 0.2rem rgba(79, 156, 255, 0.15);
    }

    .image-box {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 12px;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      background: #fafafa;
    }

    .image-box img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
    }

    .btn-primary {
      border-radius: 10px;
      padding: 10px 18px;
      font-weight: 500;
    }

    .btn-outline-secondary {
      border-radius: 10px;
    }

    .actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 10px;
    }
  </style>
</head>

<body>

  <main class="page-wrapper">

    <section class="edit-card">

      <!-- HEADER -->
      <header class="edit-header">
        <h2>Edit Product</h2>
      </header>

      <!-- FORM -->
      <div class="edit-body">

        <form action="/admin/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">

          <div class="mb-3">
            <label class="form-label">Product Name</label>
            <input type="text"
                   name="name"
                   value="<%= product.name %>"
                   class="form-control"
                   placeholder="Enter product name"
                   required>
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description"
                      class="form-control"
                      rows="4"
                      placeholder="Enter product description"><%= product.description %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label">Price (PKR)</label>
            <input type="number"
                   name="price"
                   value="<%= product.price %>"
                   class="form-control"
                   step="any"
                   required>
          </div>

          <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="category" class="form-select" required>
              <option value="" disabled>Select Category</option>
              <option value="Electronics" <%= product.category === 'Electronics' ? 'selected' : '' %>>
                Electronics
              </option>
              <option value="Fashion" <%= product.category === 'Fashion' ? 'selected' : '' %>>
                Fashion
              </option>
              <option value="Home" <%= product.category === 'Home' ? 'selected' : '' %>>
                Home
              </option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Stock Quantity</label>
            <input type="number"
                   name="stock"
                   value="<%= product.stock %>"
                   class="form-control"
                   required>
          </div>

          <!-- IMAGE SECTION -->
          <div class="mb-3">
            <label class="form-label d-block">Product Image</label>

            <div class="image-box">

              <div class="text-center">
                <small class="text-muted d-block mb-1">Current</small>
                <img src="<%= product.image %>" alt="Current product image">
              </div>

              <div class="flex-grow-1">
                <small class="text-muted d-block mb-2">
                  Upload a new image to replace the current one
                </small>
                <input type="file" name="image" class="form-control">
              </div>

            </div>
          </div>

          <!-- ACTIONS -->
          <div class="actions">

            <a href="/admin/products" class="btn btn-outline-secondary">
              Cancel
            </a>

            <button type="submit" class="btn btn-primary">
              Update Product
            </button>

          </div>

        </form>

      </div>

    </section>

  </main>

</body>

</html>