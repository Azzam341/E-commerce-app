<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #f6f7fb, #eef2f7);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .dashboard-wrapper {
      padding: 30px 10px;
    }

    /* HEADER */
    .dashboard-header {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 15px;
      margin-bottom: 25px;
    }

    .dashboard-title {
      font-weight: 800;
      letter-spacing: -0.5px;
      margin: 0;
    }

    .action-buttons a {
      border-radius: 10px;
      padding: 8px 14px;
      font-weight: 500;
      transition: 0.2s ease;
    }

    .action-buttons a:hover {
      transform: translateY(-2px);
    }

    /* ALERT */
    .alert {
      border-radius: 12px;
    }

    /* TABLE CARD */
    .table-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      overflow: hidden;
    }

    .table-header {
      padding: 14px 18px;
      border-bottom: 1px solid #eef0f3;
      font-weight: 600;
    }

    table {
      min-width: 900px;
    }

    /* IMAGE */
    .product-img {
      width: 55px;
      height: 55px;
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid #e5e7eb;
    }

    /* BADGE */
    .category-badge {
      background: #e5e7eb;
      color: #374151;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
    }

    /* ACTION BUTTONS */
    .btn-sm {
      border-radius: 10px;
    }

    .btn-primary {
      border-radius: 10px;
    }

    .btn-danger {
      border-radius: 10px;
    }
  </style>
</head>

<body>

  <main class="dashboard-wrapper container-fluid container-md">

    <!-- HEADER -->
    <header class="dashboard-header">

      <h2 class="dashboard-title">Admin Dashboard</h2>

      <div class="action-buttons d-flex gap-2 flex-wrap">

        <a href="/admin/add" class="btn btn-success">
          + Add Product
        </a>

        <a href="/admin/analytics" class="btn btn-info text-white">
          Analytics
        </a>

        <a href="/logout" class="btn btn-danger">
          Logout
        </a>

      </div>

    </header>

    <!-- SUCCESS ALERT -->
    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= successMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- TABLE -->
    <section class="table-card">

      <div class="table-header">
        Products
      </div>

      <div class="table-responsive p-2 p-md-3">

        <table class="table table-hover align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Price</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Image</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>

            <% if (products.length > 0) { %>
              <% products.forEach(p => { %>
                <tr>

                  <td class="fw-semibold">
                    <%= p.name %>
                  </td>

                  <td>
                    PKR <%= p.price.toLocaleString() %>
                  </td>

                  <td>
                    <span class="category-badge">
                      <%= p.category %>
                    </span>
                  </td>

                  <td>
                    <%= p.stock %>
                  </td>

                  <td>
                    <img src="<%= p.image %>"
                         alt="<%= p.name %>"
                         class="product-img">
                  </td>

                  <td>
                    <div class="d-flex gap-2 flex-wrap">

                      <a href="/admin/edit/<%= p._id %>"
                         class="btn btn-primary btn-sm">
                        Edit
                      </a>

                      <a href="/admin/delete/<%= p._id %>"
                         onclick="return confirm('Delete this product?')"
                         class="btn btn-danger btn-sm">
                        Delete
                      </a>

                    </div>
                  </td>

                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">
                  No products found
                </td>
              </tr>
            <% } %>

          </tbody>

        </table>

      </div>

    </section>

  </main>

</body>

</html>