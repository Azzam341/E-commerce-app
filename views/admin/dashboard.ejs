<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Admin Dashboard</h2>

    <div class="d-flex gap-2">

      <a href="/admin/add" class="btn btn-success">
        + Add Product
      </a>

      <a href="/admin/analytics" class="btn btn-info">
        Analytics
      </a>

      <a href="/logout" class="btn btn-danger">
        Logout
      </a>

    </div>

  </div>

  <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= successMessage %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <h4 class="mb-3">Products</h4>

  <table class="table table-striped table-bordered align-middle">

    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Price</th>
        <th>Category</th>
        <th>Stock</th>
        <th style="width: 100px;">Image</th>
        <th style="width: 180px;">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if (products.length > 0) { %>
        <% products.forEach(p => { %>
          <tr>

            <td class="fw-semibold"><%= p.name %></td>
            <td>PKR <%= p.price.toLocaleString() %></td>
            <td><span class="badge bg-secondary"><%= p.category %></span></td>
            <td><%= p.stock %></td>

            <td>
              <img src="<%= p.image %>" 
                   alt="<%= p.name %>" 
                   class="img-thumbnail" 
                   style="width: 60px; height: 60px; object-fit: cover; display: block;">
            </td>

            <td>
              <div class="d-flex gap-1">
                <a href="/admin/edit/<%= p._id %>" class="btn btn-primary btn-sm">
                  Edit
                </a>

                <a href="/admin/delete/<%= p._id %>"
                   onclick="return confirm('Delete this product?')"
                   class="btn btn-danger btn-sm">
                  Delete
                </a>
              </div>
            </td>

          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" class="text-center text-muted py-4">No products found</td>
        </tr>
      <% } %>

    </tbody>

  </table>

</div>

</body>
</html>