<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #f6f7fb, #eef2f7);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    }

    .dashboard-wrapper {
      padding: 25px 10px;
    }

    .dashboard-title {
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .back-btn {
      border-radius: 10px;
    }

    /* STAT CARDS */
    .stat-card {
      border: none;
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      transition: 0.2s ease;
      height: 100%;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    }

    .stat-label {
      font-size: 13px;
      color: #6b7280;
    }

    .stat-value {
      font-size: clamp(1.3rem, 2vw, 2rem);
      font-weight: 800;
      color: #111827;
    }

    /* TABLE CARD */
    .table-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      overflow: hidden;
    }

    .table-header {
      padding: 15px 18px;
      border-bottom: 1px solid #eef0f3;
      font-weight: 600;
    }

    table {
      min-width: 900px;
    }

    /* STATUS FORM */
    .status-form select {
      border-radius: 10px;
    }

    .status-form button {
      border-radius: 10px;
    }

    /* BADGE */
    .badge-soft {
      background: #e5e7eb;
      color: #374151;
    }
  </style>
</head>

<body>

  <main class="dashboard-wrapper container-fluid container-md">

    <!-- HEADER -->
    <header class="mb-4">
      <a href="/admin" class="btn btn-outline-secondary back-btn mb-3">
        ← Back to Dashboard
      </a>

      <h2 class="dashboard-title mb-1">Admin Dashboard</h2>
      <p class="text-muted small mb-0">Overview of orders, revenue, and activity</p>
    </header>

    <!-- STATS -->
    <section class="row g-3 mb-4">

      <div class="col-12 col-sm-6 col-md-4">
        <div class="stat-card p-3">
          <div class="stat-label">Total Orders</div>
          <div class="stat-value"><%= totalOrders %></div>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-md-4">
        <div class="stat-card p-3">
          <div class="stat-label">Total Revenue</div>
          <div class="stat-value">
            PKR <%= totalRevenue.toLocaleString() %>
          </div>
        </div>
      </div>

    </section>

    <!-- TABLE -->
    <section class="table-card">

      <div class="table-header">
        Order History
      </div>

      <div class="p-2 p-md-3 table-responsive">

        <table class="table table-hover align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>Order ID</th>
              <th>User</th>
              <th>Email</th>
              <th>Items</th>
              <th>Total</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>

          <tbody>

            <% if (recentOrders.length > 0) { %>
              <% recentOrders.forEach(order => { %>
                <tr>

                  <td class="small text-truncate" style="max-width:120px;">
                    <%= order._id %>
                  </td>

                  <td>
                    <%= order.user?.name || 'Guest' %>
                    <% if (order.isGuest) { %>
                      <span class="badge badge-soft ms-2">Guest</span>
                    <% } %>
                  </td>

                  <td class="small text-muted">
                    <%= order.user?.email || order.shippingAddress?.email || 'N/A' %>
                  </td>

                  <td>
                    <ul class="mb-0 ps-3 small">
                      <% order.items.forEach(item => { %>
                        <li>
                          <strong><%= item.name %></strong>
                          x <%= item.quantity %>
                        </li>
                      <% }) %>
                    </ul>
                  </td>

                  <td class="fw-semibold small">
                    PKR <%= order.totalPrice.toLocaleString() %>
                  </td>

                  <td>
                    <form method="POST"
                          action="/admin/order/<%= order._id %>/status"
                          class="status-form d-flex flex-column flex-lg-row gap-2">

                      <select name="status" class="form-select form-select-sm">
                        <% ['Placed','Processing','Shipped','Delivered','Cancelled'].forEach(s => { %>
                          <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>>
                            <%= s %>
                          </option>
                        <% }) %>
                      </select>

                      <button class="btn btn-sm btn-primary">
                        Update
                      </button>

                    </form>
                  </td>

                  <td class="small text-muted">
                    <%= order.createdAt.toLocaleString() %>
                  </td>

                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No order history found
                </td>
              </tr>
            <% } %>

          </tbody>

        </table>

      </div>

    </section>

  </main>

</body>

</html>