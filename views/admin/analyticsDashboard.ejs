<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container py-4">

  <h2 class="mb-4">Admin Dashboard</h2>

  <!-- STATS CARDS -->
  <div class="row mb-4">

    <div class="col-md-4">
      <div class="card p-3 shadow-sm">
        <h5>Total Orders</h5>
        <h3><%= totalOrders %></h3>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow-sm">
        <h5>Total Revenue</h5>
        <h3>PKR <%= totalRevenue.toLocaleString() %></h3>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow-sm">
        <h5>Top Product</h5>

        <% if(topProducts.length > 0) { %>
          <h4><%= topProducts[0].name %></h4>
          <small>Sold: <%= topProducts[0].sold %></small>
        <% } else { %>
          <p>No data</p>
        <% } %>

      </div>
    </div>

  </div>

  <!-- TOP PRODUCTS TABLE -->
  <h4>Top Selling Products</h4>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Product</th>
        <th>Units Sold</th>
      </tr>
    </thead>

    <tbody>
      <% topProducts.forEach(p => { %>
        <tr>
          <td><%= p.name %></td>
          <td><%= p.sold %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- RECENT ORDERS -->
  <h4 class="mt-5">Recent Orders</h4>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>User</th>
        <th>Email</th>
        <th>Total</th>
        <th>Status</th>
      </tr>
    </thead>

    <tbody>
      <% recentOrders.forEach(order => { %>
        <tr>
          <td><%= order.user?.name %></td>
          <td><%= order.user?.email %></td>
          <td>PKR <%= order.totalPrice %></td>
          <td><%= order.status %></td>
        </tr>
      <% }) %>
    </tbody>

  </table>

</div>

</body>
</html>